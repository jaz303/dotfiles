[user]
	email = jwf@jasonframe.co.uk
	name = Jason Frame
[alias]
    branches = branch -a
    co = checkout
    ci = commit
    me = merge
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
[apply]
    whitespace = nowarn
[color]
    branch = auto
    diff = auto
    status = auto
[color "branch"]
    current = green
    local = blue
    remote = cyan
[color "status"]
    added = yellow
    changed = green
    untracked = cyan
[github]
    user = jaz303
[core]
	quotepath = false
	excludesfile = ~/.gitignore
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/
[pull]
	rebase = false
[safe]
	directory = /opt/homebrew/Caskroom/flutter/3.32.2/flutter
